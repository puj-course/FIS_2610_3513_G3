# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE BASE DE DATOS
# ═══════════════════════════════════════════════════════════════════════════

# Usuario de PostgreSQL
DB_USER=entregaya_user

# Contraseña de PostgreSQL (CAMBIAR EN PRODUCCIÓN)
DB_PASSWORD=tu_password_real

# Nombre de la base de datos
DB_NAME=entregaya

# Host de la base de datos (en Docker: nombre del servicio)
DB_HOST=postgres

# Puerto de PostgreSQL
DB_PORT=5432

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE PGADMIN
# ═══════════════════════════════════════════════════════════════════════════

# Email para acceder a pgAdmin (http://localhost:8080)
PGADMIN_EMAIL=admin@entregaya.com

# Contraseña para pgAdmin (CAMBIAR EN PRODUCCIÓN)
PGADMIN_PASSWORD=admin123

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE TELEGRAM BOT (OPCIONAL)
# ═══════════════════════════════════════════════════════════════════════════

# Token del bot de Telegram (dejar como SIN_CONFIGURAR si no se usa)
TELEGRAM_BOT_TOKEN=SIN_CONFIGURAR

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE LA APLICACIÓN
# ═══════════════════════════════════════════════════════════════════════════

# Puerto donde escucha la aplicación Spring Boot
SERVER_PORT=8081

# Perfil activo de Spring
SPRING_PROFILES_ACTIVE=docker
